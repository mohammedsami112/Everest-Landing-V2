# Template for php/.env — copy to .env and fill in the real values.
# Values are taken literally (optionally wrap in quotes); # starts a comment line.

# Database (MySQL)
DB_HOST=localhost
DB_NAME=your_database
DB_USER=your_user
DB_PASS=your_password

# Telegram lead notifications (Nabd network)
TELEGRAM_BOT_TOKEN=123456789:replace-with-bot-token
TELEGRAM_CHAT_NABD_ALL=-100xxxxxxxxxx
TELEGRAM_CHAT_NABD_COUNT=-100xxxxxxxxxx
